# URL of the deployed dischem-bi-manager web app (no trailing slash)
DCHEM_API_URL=https://dischem-bi-manager.vercel.app

# Resend API key for email alerts
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email sender (must be a verified domain in Resend)
EMAIL_FROM=report_sender@outerjoin.co.za

# Set to "true" to actually send alert emails (leave unset or "false" during testing)
SEND_ALERTS=false
